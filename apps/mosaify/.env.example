# Spotify OAuth — Authorization Code + PKCE (browser SPA, no secret).
#
# The client ID is PUBLIC and safe to commit/ship. Copy this file to
# `.env.local` and fill in your value from the Spotify Developer Dashboard.
#
# NEVER put the client SECRET here or anywhere in this app — it would be
# exposed in the browser bundle. The secret is only for a server-side
# (confidential) client. If you leaked it, rotate it in the dashboard.

VITE_SPOTIFY_CLIENT_ID=

# Must exactly match a Redirect URI registered on your Spotify app.
# Spotify rejects "localhost" — use the loopback IP.
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:4200/
